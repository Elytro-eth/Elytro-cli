ELYTRO_ENV=development
# Pimlico API key used for sponsored UserOperations (falls back to public endpoint if omitted)
# ELYTRO_PIMLICO_KEY=replace-with-pimlico-api-key
# Alchemy project key for default RPCs (override with ELYTRO_RPC_URL_* if you prefer another provider)
# ELYTRO_ALCHEMY_KEY=replace-with-alchemy-api-key
# Optional RPC overrides (set full URLs, e.g. Infura/QuickNode)
# ELYTRO_RPC_URL_1=https://mainnet.infura.io/v3/your-key
